# Exemplo de .env para usar com Neon/Postgres
# Substitua pelos valores do seu projeto Neon
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
NEON_AUTH_URL=https://auth.your-neon-project.neon.tech
NEON_AUTH_KEY=your-neon-auth-secret
